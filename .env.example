# --- Google OAuth (opciono) ---
# Iz Google Cloud Console (OAuth client, Web application).
# Redirect URI u Google konzoli: http://127.0.0.1:54321/auth/v1/callback
# Posle popunjavanja: u supabase/config.toml [auth.external.google] enabled = true, pa restart.
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=
